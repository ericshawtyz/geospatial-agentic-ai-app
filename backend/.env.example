# OneMap API credentials (register at https://www.onemap.gov.sg/apidocs/register)
ONEMAP_EMAIL=your-email@example.com
ONEMAP_PASSWORD=your-onemap-password

# URA API credentials (register at https://eservice.ura.gov.sg/maps/api/reg.html)
URA_ACCESS_KEY=your-ura-access-key

# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# Agent runtime mode.
# - chat_completion (default): in-process agent + local/HTTP MCP tools, intended for dev.
# - foundry_agent_service: upserts a hosted agent in Foundry Agent Service that
#   calls the deployed MCP Container Apps directly. Requires *_MCP_URL below.
AGENT_MODE=chat_completion
# Name of the hosted Foundry agent (only used when AGENT_MODE=foundry_agent_service).
# Re-used (upserted) on each backend restart so identity stays stable across deploys.
FOUNDRY_AGENT_NAME=geo-agent

# Azure Content Understanding (optional, for document/media processing)
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=https://<resource>.cognitiveservices.azure.com
